{
  "name": "corn-classifier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup:dev": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-dev.ps1",
    "dev": "concurrently -k -n frontend,backend \"next dev\" \"npm run backend:dev\"",
    "backend:dev": "cd backend && ..\\.venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "next": "^16.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
